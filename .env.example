HF_TOKEN=hf_your_token_here
MAGENTA_RT_DEFAULT_MODEL=mrt2_small
MAGENTA_RT_BACKEND=mlxfn
MAGENTA_RT_PRELOAD_MODELS=mrt2_small
MAGENTA_RT_MAX_DURATION=60
MAGENTA_RT_MAX_BATCH_SIZE=4
MAGENTA_RT_MAX_UPLOAD_BYTES=104857600
MAGENTA_RT_MLXFN_WARMUP_STEPS=5

# Magenta's upstream package stores resources under:
#   $MAGENTA_HOME/magenta-rt-v2
# Leave unset to use ~/Documents/Magenta/magenta-rt-v2.
# MAGENTA_HOME=/Users/you/Documents/Magenta

# Set to true if you want the API to invoke upstream download commands when
# resources are missing. For production, pre-download assets during provisioning.
MAGENTA_RT_AUTO_DOWNLOAD=false

# Job output storage. Leave bucket unset for local ./outputs storage.
MAGENTA_RT_OUTPUT_DIR=outputs
# MAGENTA_RT_STORAGE_BUCKET=your-bucket
# MAGENTA_RT_STORAGE_PREFIX=magenta-rt/jobs
# MAGENTA_RT_STORAGE_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com
# MAGENTA_RT_STORAGE_REGION=auto
# MAGENTA_RT_STORAGE_PUBLIC_BASE_URL=https://cdn.example.com
# MAGENTA_RT_PRESIGNED_URL_EXPIRES=3600

# Vite dev server origin for local dashboard development.
MAGENTA_RT_CORS_ORIGINS=http://localhost:5173
